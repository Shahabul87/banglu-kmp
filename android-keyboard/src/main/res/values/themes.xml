<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BangluKeyboard" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@android:color/holo_blue_light</item>
    </style>

    <style name="Theme.Hidden" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
</resources>
