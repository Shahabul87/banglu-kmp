<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- windowLightNavigationBar exists from API 27; the base theme (minSdk 24)
         must not reference it (lint NewApi error). -->
    <style name="Theme.BangluKeyboard" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@android:color/holo_blue_light</item>
    </style>
</resources>
